# HTTP
PORT=8080
LISTEN_ADDR=:8080

# PostgreSQL
POSTGRES_DSN=postgres://iot:iot123@localhost:5432/iot?sslmode=disable

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=iot.telemetry
KAFKA_COMMAND_TOPIC=iot.command

# EMQX / MQTT
EMQX_URL=tcp://127.0.0.1:1883
EMQX_TOPIC_FILTER=tenant/+/device/+/telemetry
EMQX_CLIENT_ID=iot-ingress

# TDengine
TDENGINE_DSN='root:taosdata@http(127.0.0.1:6041)/iot'
TDENGINE_TABLE=telemetry

# Demo simulator
DEMO_ADMIN_URL=http://127.0.0.1:8080
DEMO_MQTT_URL=tcp://127.0.0.1:1883
DEMO_TENANT_COUNT=5
DEMO_DEVICES_PER_TENANT=10
DEMO_TENANT_PREFIX=demo
DEMO_PRODUCT_ID=product-demo
DEMO_TICK_INTERVAL=250ms
DEMO_TELEMETRY_BURST_MIN=1
DEMO_TELEMETRY_BURST_MAX=5
DEMO_COMMAND_BURST_MIN=1
DEMO_COMMAND_BURST_MAX=3
